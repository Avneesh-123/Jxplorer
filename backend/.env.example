HOST=0.0.0.0
PORT=1337
NODE_ENV=production

APP_KEYS="replace-with-random-key-1,replace-with-random-key-2"
API_TOKEN_SALT=replace-with-random-string
ADMIN_JWT_SECRET=replace-with-random-string
